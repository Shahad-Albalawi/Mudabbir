# --- OS & editors ---
.DS_Store
Thumbs.db
*.log
*.stackdump
.env.local
.env.*.local

.idea/
*.iml
.cursor/

# --- Flutter (frontend/) ---
frontend/*.zip
frontend/lib/**/*.zip
frontend/build/
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/android/.gradle/
frontend/android/app/.cxx/
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/
