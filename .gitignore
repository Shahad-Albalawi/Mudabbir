backend/.phpunit.cache/
backend/.phpunit.result.cache
backend/storage/*.key
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitignore

# --- Secrets (any path) ---
*.jks
*.keystore
**/key.properties
frontend/.env
