# Render environment (paste in Dashboard -> Environment)

APP_NAME=Mudabbir
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mudabbir-backend-api.onrender.com
APP_KEY=REPLACE-WITH-key:generate-output

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# AI coach (optional — chatbot works with local fallback if empty)
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Budget push alerts (optional)
FCM_SERVER_KEY=

# On Render: add a Cron Job running `php artisan schedule:run` daily for budget alerts.

TRUSTED_PROXIES=*
